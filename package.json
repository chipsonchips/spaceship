{
  "name": "spaceship",
  "version": "1.0.0",
  "private": true,
  "description": "Spaceship Game - Full Stack Application",
  "scripts": {
    "install:all": "pnpm install && pnpm --filter spaceship-backend install && pnpm --filter spaceship install",
    "dev": "pnpm --parallel --filter spaceship-backend --filter spaceship dev",
    "build": "pnpm --parallel --filter spaceship-backend --filter spaceship build",
    "start": "pnpm --parallel --filter spaceship-backend --filter spaceship start",
    "lint": "pnpm --parallel --filter spaceship-backend --filter spaceship lint",
    "format": "pnpm --parallel --filter spaceship-backend --filter spaceship format",
    "backend:dev": "pnpm --filter spaceship-backend dev",
    "frontend:dev": "pnpm --filter spaceship dev",
    "backend:build": "pnpm --filter spaceship-backend build",
    "frontend:build": "pnpm --filter spaceship build",
    "backend:start": "pnpm --filter spaceship-backend start",
    "frontend:start": "pnpm --filter spaceship start",
    "backend:lint": "pnpm --filter spaceship-backend lint",
    "frontend:lint": "pnpm --filter spaceship lint",
    "test": "pnpm --parallel --filter spaceship-backend --filter spaceship test:run",
    "test:watch": "pnpm --parallel --filter spaceship-backend --filter spaceship test",
    "test:ui": "pnpm --parallel --filter spaceship-backend --filter spaceship test:ui",
    "test:coverage": "pnpm --parallel --filter spaceship-backend --filter spaceship test:coverage",
    "backend:test": "pnpm --filter spaceship-backend test:run",
    "backend:test:watch": "pnpm --filter spaceship-backend test",
    "backend:test:ui": "pnpm --filter spaceship-backend test:ui",
    "frontend:test": "pnpm --filter spaceship test:run",
    "frontend:test:watch": "pnpm --filter spaceship test",
    "frontend:test:ui": "pnpm --filter spaceship test:ui",
    "migration:run": "pnpm --filter spaceship-backend exec tsx src/scripts/run-migrations.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.10.0"
}